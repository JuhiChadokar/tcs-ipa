import java.util.*;
class Course{
    private int courseId;
    private String courseName;
    private String courseAdmin;
    private int quiz;
    private int handson;
    public Course(int courseId,String courseName,String courseAdmin,int quiz,int handson){
        this.courseId=courseId; this.courseName=courseName;
        this.courseAdmin=courseAdmin; this.quiz=quiz; this.handson=handson;
    }
    public int getCourseId(){return courseId;}
    public String getCourseName(){return courseName;}
    public String getCourseAdmin(){return courseAdmin;}
    public int getQuiz(){return quiz;}
    public int getHandson(){return handson;}
}
    
public class Xplore{
        public static void main(String[] args){
            Scanner sc =new Scanner(System.in);
            Course[] course=new Course[4];
            for(int i =0;i<course.length;i++){
                int a=sc.nextInt(); sc.nextLine();
                String b=sc.nextLine();
                String c=sc.nextLine();
                int d=sc.nextInt();sc.nextLine();
                int e=sc.nextInt();sc.nextLine();
                course[i]= new Course(a,b,c,d,e);
            }
            String name=sc.nextLine();
            int no=sc.nextInt();
            int result1=findAvgOfQuizByAdmin(course,name);
            if(result1 !=0){System.out.println(result1);}
            else System.out.println("No Course found");
            Course [] result2= sortCourseByHandsOn(course,no );
            if (result2.length>0){
                for(Course x:result2){
                    System.out.println(x.getCourseName());
                }
            }
            else System.out.println("No Course found with mentioned attribute.");
            
        }
        public static int findAvgOfQuizByAdmin(Course[] course,String cAdmin){
            int sum=0; int idx=0;
            for(int i =0;i<course.length;i++){
                if(course[i].getCourseAdmin().equalsIgnoreCase(cAdmin)){
                    sum+=course[i].getQuiz();idx++;
                }
            }
            if(idx!=0){System.out.println(sum+" "+idx);
                return sum/idx;}
            else{return 0;}
        }
        public static Course[] sortCourseByHandsOn(Course[] course,int handson ){
            int cnt=0;
            for(Course crse:course){
                if (crse.getHandson()<handson){
                    cnt++;}
            }
            Course[] result=new Course[cnt];
            int l=0;
            for(Course j:course){
                if (j.getHandson()<handson) {
                    result[l++]=j;
                    
                }
            }
            
            for(int i =0;i<result.length-1;i++){
                for(int j=i+1;j<result.length;j++){
                    if(result[i].getHandson()>result[j].getHandson()){
                        Course val=result[i];
                        result[i]=result[j];
                        result[j]=val;
                    }
                }
            }
            if(result.length!=0){
                return result;
            }
            else return null;
        }
}
