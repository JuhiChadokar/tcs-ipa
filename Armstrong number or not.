/*Write a Java program to check if a given number is an Armstrong number or not.

Here's an example of the expected input and output:

Input number: 153
Output: "Yes, the number is an Armstrong number."

*/

import java.util.*;
public class Main{
    public static void main (String[] args){
        Scanner sc =new Scanner(System.in);
        int a=sc.nextInt();
        int no=a;
        int power=String.valueOf(a).length();
        int sum=0;
        for(int i=0;i<power;i++){
            int lastDigit=no%10;
            sum+=Math.pow(lastDigit,power);
            no=no/10;
        } 
        if(sum==a) System.out.println(" is armstrong no");
        else System.out.println("not");
    }
}
